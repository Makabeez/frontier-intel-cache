# --- Frontier Intel Cache backend env ---

# Port the FastAPI server binds to
PORT=8090

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Local SQLite cache for indexed intel events
SQLITE_PATH=./intel-cache.sqlite

# Indexer polling cadence (seconds). 5s is a good balance.
INDEXER_POLL_SECONDS=5

# CORS — comma-separated origins. Use * for dev, lock down for prod.
CORS_ORIGINS=*

# --- Walrus testnet (defaults; override only if rate-limited) ---
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# --- Tatum Sui RPC ---
# Testnet is the right choice while Walrus is testnet-only
TATUM_SUI_RPC_URL=https://sui-testnet.gateway.tatum.io

# Get from https://dashboard.tatum.io (optional for read methods; required for rate limits)
TATUM_API_KEY=

# --- Move package ---
# Set this AFTER you `sui client publish` the smart-contract/ package on Sui testnet.
# Indexer is idle until this is set.
FRONTIER_INTEL_PACKAGE_ID=
