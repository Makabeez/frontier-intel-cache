# --- Frontier Intel Cache frontend env ---

# Backend API base. Vite dev server proxies /api → here; in production this is the public URL.
VITE_API_URL=http://localhost:8090

# Walrus aggregator (public reads)
VITE_WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space

# On-chain identifiers — match what's in backend/.env
VITE_PACKAGE_ID=0x5fecdeefa2227a7d5f2ac432c27a6927933fe03b93c0e9d0560022f8a9781741
VITE_BEACON_ID=0x91dfc5a879265527ee7932b9bf9101951d418ff6a916a07c9df337954b7a73c8

# Network — testnet for now
VITE_SUI_NETWORK=testnet
